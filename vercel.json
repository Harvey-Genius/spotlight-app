{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/success.html", "dest": "/success.html" },
    { "src": "/google6d1fcbad6b3382ff.html", "dest": "/google6d1fcbad6b3382ff.html" },
    { "src": "/spotlight-extension.zip", "dest": "/spotlight-extension.zip" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "^/$", "dest": "/landing.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
